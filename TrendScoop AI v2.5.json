    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const text = (item.json.clean_article || \"\").toLowerCase()\n\n  let score = 0;\n\n  // Strong local relevance\n  if (text.includes(\"mira bhayandar\")) score += 5;\n  if (text.includes(\"bhayandar\")) score += 3;\n  if (text.includes(\"mira road\")) score += 3;\n  if (text.includes(\"mumbai\")) score += 1;\n\n  // Civic bodies\n  if (text.includes(\"mbmc\")) score += 4;\n  if (text.includes(\"bmc\")) score += 3;\n  if (text.includes(\"mmrda\")) score += 3;\n\n  // Infrastructure / public works\n  if (text.includes(\"road\") || text.includes(\"bridge\")) score += 2;\n  if (text.includes(\"metro\") || text.includes(\"rail\")) score += 2;\n  if (text.includes(\"water\") || text.includes(\"drain\")) score += 2;\n\n  // Financial or scale indicators\n  if (text.match(/₹|crore|lakh|km|%|\\d+/)) score += 2;\n\n  // Urgency indicators\n  if (text.includes(\"fire\") || text.includes(\"accident\")) score += 3;\n  if (text.includes(\"protest\") || text.includes(\"shutdown\")) score += 2;\n\n  // Penalize very short content\n  if (text.length < 500) score -= 2;\n\n  return {\n    json: {\n      ...item.json,\n      impact_score: score\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
