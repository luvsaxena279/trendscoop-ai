      "parameters": {
        "jsCode": "const sentItems = $items(\"09 Load: Sent URL Log\", 0, 0) || [];\n\nconst sentUrls = new Set(\n  sentItems\n    .map(item => item.json.URL)\n    .filter(Boolean)\n);\n\nreturn items.filter(item => {\n  const url = item.json.url;\n  return url && !sentUrls.has(url);\n});"
      },
