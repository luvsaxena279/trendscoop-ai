      "parameters": {
        "jsCode": "return [\n  {\n    json: {\n      choices: [\n        {\n          message: {\n            content: `\nHeadline: No Major Updates Today\n\nBriefing:\nThere were no significant new civic developments in the last 24 hours in Mira Bhayandar.\n\nWe’ll return tomorrow at 8AM with fresh local updates.\n            `\n          }\n        }\n      ]\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2224,
        -48
