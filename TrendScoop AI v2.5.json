      "id": "7a696ad4-1ee8-4a9b-813c-171f4b1f5c0b",
      "name": "20 Fallback: No Stories Template"
    },
    {
      "parameters": {
        "jsCode": "const raw = items[0].json.text || \"\";\n\n// Split headline and briefing safely\nlet headline = \"Today's Civic Briefing\";\nlet briefing = raw;\n\nif (raw.includes(\"Headline:\")) {\n  const parts = raw.split(\"Headline:\");\n  if (parts[1]) {\n    const headlineSplit = parts[1].split(\"\\n\");\n    headline = headlineSplit[0].trim();\n    briefing = raw.replace(`Headline: ${headline}`, \"\").trim();\n  }\n}\n\nconst name = items[0].json.Name || \"Subscriber\";\nconst locale = items[0].json.Locale || \"your area\";\n\nconst html = `\n<div style=\"font-family: Arial, sans-serif; max-width:600px; margin:auto;\">\n  <h1>TrendScoop AI</h1>\n  <p style=\"color:#444;\">\n    Hi ${name}, here is today's civic briefing for ${locale}.\n  </p>\n\n  <h2>${headline}</h2>\n\n  <div style=\"color:#444; line-height:1.6; font-size:15px;\">\n    ${briefing.replace(/\\n/g, \"<br><br>\")}\n  </div>\n\n  <p style=\"font-size:12px; color:#888; text-align:center; margin-top:40px;\">\n    You’re receiving this because you subscribed to TrendScoop AI.\n  </p>\n</div>\n`;\n\nreturn [{ json: { html } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
